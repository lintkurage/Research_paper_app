{
  "manifest_version": 3,
  "name": "Aurelia - 論文追加",
  "description": "arXiv などの論文ページをワンクリックで Aurelia に追加",
  "version": "1.1",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:5001/*"
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aurelia に追加",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
